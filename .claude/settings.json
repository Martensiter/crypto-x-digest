{
  "permissions": {
    "allow": [
      "Bash(git *)",
      "Bash(python scripts/*)",
      "Bash(python3 scripts/*)",
      "Bash(pip install *)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/session_start.sh",
            "timeout": 10000
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash routines/auto-checkpoint.sh"
          }
        ]
      }
    ]
  }
}
